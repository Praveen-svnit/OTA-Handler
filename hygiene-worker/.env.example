# Copy this file to ".env" and fill in the values.

# The Google Apps Script web-app URL (ends in /exec) — the SAME URL used in
# ota-handler/docs/assets/api.js (GAS_URL). Ask your admin if unsure.
GAS_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# Shared secret — must match the WORKER_TOKEN script property set on the
# Apps Script project (Project Settings -> Script properties).
WORKER_TOKEN=ask-your-admin

# IMPORTANT: this MUST equal the name you type on the Hygiene Scrape page.
# Jobs you queue there are routed to the worker whose name matches.
WORKER_NAME=Your Name

# DevTools port used by launch-chrome.bat (change only if 9222 is taken).
CDP_PORT=9222

# How often (seconds) to poll for new jobs.
POLL_INTERVAL=4

# Max seconds to spend scraping one property before giving up.
JOB_TIMEOUT=120
