# Copy this file to ".env". The SAME file works on every team PC — there's
# nothing to personalise (shared Booking.com account = shared job pool).

# The Google Apps Script web-app URL (ends in /exec) — the SAME URL used in
# ota-handler/docs/assets/api.js (GAS_URL). Ask your admin if unsure.
GAS_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# Shared secret — must match the WORKER_TOKEN script property set on the
# Apps Script project (Project Settings -> Script properties).
WORKER_TOKEN=ask-your-admin

# ── Optional (defaults are fine) ───────────────────────────────────────────
# WORKER_NAME — only a label in the activity log; defaults to this PC's name.
# WORKER_NAME=
# CDP_PORT — DevTools port from launch-chrome.bat (change only if 9222 is taken).
CDP_PORT=9222
# POLL_INTERVAL — seconds between checks for new jobs.
POLL_INTERVAL=4
# JOB_TIMEOUT — max seconds to scrape one property before giving up.
JOB_TIMEOUT=120
